APP_NAME="Art Market"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=Asia/Jakarta
APP_URL=http://localhost

APP_LOCALE=id
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=id_ID

APP_MAINTENANCE_DRIVER=file
APP_MAINTENANCE_STORE=database

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=art_market
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=file
CACHE_PREFIX=

SCOUT_DRIVER=database
SEARCH_DRIVER=database
REALTIME_DRIVER=sse
REALTIME_POLLING_INTERVAL_SECONDS=10
REALTIME_SSE_MAX_EXECUTION_SECONDS=55
REALTIME_SSE_HEARTBEAT_SECONDS=15
REALTIME_SSE_RETRY_MILLISECONDS=1000
REALTIME_HIDDEN_TAB_CLOSE_SECONDS=60

MARKETPLACE_CURRENCY=IDR
MARKETPLACE_COMMISSION_RATE=0.10
MARKETPLACE_WITHDRAW_MINIMUM=100000
MARKETPLACE_WITHDRAW_FEE=6500
MARKETPLACE_WITHDRAW_SCHEDULE=weekly
MARKETPLACE_SHIPPING_MODE=manual
MARKETPLACE_PRODUCT_AUTO_PUBLISH=true
MARKETPLACE_REFERRAL_REWARD_AMOUNT=50000

PAYMENT_DRIVER=midtrans
MIDTRANS_SERVER_KEY=
MIDTRANS_CLIENT_KEY=
MIDTRANS_MERCHANT_ID=
MIDTRANS_IS_PRODUCTION=false

NOTIFICATION_DRIVER=database

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
